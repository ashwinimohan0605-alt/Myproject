Problem 10(Rubtime Polymorphism with array of objects) :
#include <iostream>
using namespace std;

class Animal {
public:
    virtual void speak() {
        cout << "Animal speaks\n";
    }
};

class Cat : public Animal {
public:
    void speak() {
        cout << "Cat meows\n";
    }
};

class Dog : public Animal {
public:
    void speak() {
        cout << "Dog barks\n";
    }
};

int main() {
    Animal* a[2];
    Cat c;
    Dog d;

    a[0] = &c;
    a[1] = &d;

    for(int i = 0; i < 2; i++) {
        a[i]->speak();
    }
}
